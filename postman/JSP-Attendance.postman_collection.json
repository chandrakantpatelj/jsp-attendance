{
  "info": {
    "_postman_id": "b2f1f7b2-4c8b-4d2a-9e3b-10c9e9e5a9d3",
    "name": "JSP Attendance",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Auth - Fetch CSRF Token (GET /login)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login page loaded', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 302]);",
                  "});",
                  "",
                  "// Extract Laravel CSRF token from the login HTML (hidden _token input)",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.text();",
                  "  const m = body.match(/name=\\\"_token\\\"\\s+value=\\\"([^\\\"]+)\\\"/);",
                  "  if (m && m[1]) {",
                  "    pm.collectionVariables.set('csrfToken', m[1]);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Auth - Login (POST /login)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "_token", "value": "{{csrfToken}}", "type": "text" },
                { "key": "email", "value": "{{email}}", "type": "text" },
                { "key": "password", "value": "{{password}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login request sent', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 302, 204]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Auth - Logout (POST /logout)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "_token", "value": "{{csrfToken}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/logout",
              "host": ["{{baseUrl}}"],
              "path": ["logout"]
            }
          }
        }
      ]
    },
    {
